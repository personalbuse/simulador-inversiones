# =============================================================================
# SIMULADOR DE INVERSIONES - CONFIGURACIÓN
# =============================================================================
# Copia este archivo a .env y configura los valores apropiados
# NO commits este archivo con valores reales

# =============================================================================
# BASE DE DATOS
# =============================================================================
POSTGRES_DB=simulador
POSTGRES_USER=simulador_user
POSTGRES_PASSWORD=genera_una_clave_segura_minimo_20_caracteres

# URL de conexión a PostgreSQL (usada por la app)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# =============================================================================
# REDIS (Caché)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# KEYS DE APIs EXTERNAS
# =============================================================================

# Finnhub - Cotizaciones de acciones (gratis hasta 60 calls/min)
# Obtén tu key en: https://finnhub.io/
FINNHUB_API_KEY=tu_finnhub_api_key_aqui

# ExchangeRate-API - Tasas de cambio (gratis hasta 1500 calls/mes)
# Obtén tu key en: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=tu_exchange_rate_api_key_aqui

# Resend - Envío de emails (gratis hasta 100 emails/mes)
# Obtén tu key en: https://resend.com/
RESEND_API_KEY=tu_resend_api_key_aqui

# =============================================================================
# SEGURIDAD
# =============================================================================

# Clave secreta para JWT (genera una nueva con: python -c "import secrets; print(secrets.token_hex(64))")
SECRET_KEY=genera_una_clave_secreta_con_python_secrets_token_hex_64

# Algoritmo JWT (HS256 recomendado)
ALGORITHM=HS256

# Expiración de tokens JWT en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Clave para endpoints de admin
ADMIN_API_KEY=admin_key_segura_genera_una_nueva

# =============================================================================
# APLICACIÓN
# =============================================================================

# Environment: development | production
ENVIRONMENT=production

# Host y puerto donde corre el servidor
HOST=0.0.0.0
PORT=8000

# TTL de caché en segundos (default: 300 = 5 minutos)
CACHE_TTL_SECONDS=300

# Rate limit: peticiones por minuto
RATE_LIMIT_PER_MINUTE=60

# URL del frontend para CORS (separadas por coma en producción)
CORS_ORIGINS=https://finsimup.app,http://localhost:5173

# URL pública del frontend
FRONTEND_URL=https://finsimup.app

# Email del remitente para emails transactionales
EMAIL_FROM=noreply@finsimup.app

# Habilitar preload de stocks y tasas al iniciar (recommended: true)
ENABLE_STARTUP_PRELOAD=true

# =============================================================================
# FIRMA DIGITAL DE PDFs (PKI)
# =============================================================================

# Directorio donde se almacenan las llaves RSA y certificado X.509
# PDF_KEYS_DIR=/app/keys/pdf_ca

# =============================================================================
# NOTAS DE DESPLIEGUE
# =============================================================================
# Para producción en AWS:
# 1. Genera claves nuevas con: python -c "import secrets; print(secrets.token_hex(64))"
# 2. Configura las API keys reales (Finnhub, ExchangeRate, Resend)
# 3. Cambia POSTGRES_PASSWORD a una clave segura
# 4. Ajusta CORS_ORIGINS a tu dominio real
# 5. Configura SSL con Cloudflare o Let's Encrypt